<% layout("layouts/boilerplate.ejs") %>

<div class="listing-controls">
    <div class="filter-strip">
        <% for (let filter of filterOptions) { %>
            <button
            class="filter-btn <%= filter.id === 'all' ? 'active' : '' %>"
            type="button"
            data-filter="<%= filter.id %>">
            <i class="<%= filter.icon %>"></i>
            <span><%= filter.label %></span>
            </button>
        <% } %>
    </div>

    <div class="listings-toolbar">
        <div class="form-check form-switch tax-toggle">
            <input class="form-check-input" type="checkbox" role="switch" id="taxSwitch">
            <label class="form-check-label" for="taxSwitch">Show 18% GST</label>
        </div>
    </div>
</div>

<div class="row" id="listing-grid">
    <% for (let listing of allListings) { %>
        <div class="col-md-4 mb-4 listing-item" data-listing-card data-category="<%= listing.category %>">
        <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card">
         <img src="<%= listing.image.url %>" class="card-img-top listing-card-img" alt="listing image">
         <div class="card-body listing-card-body">
         <h5 class="card-title"><%= listing.title %></h5>
          <p class="card-text"><%= listing.location %>, <%= listing.country %></p>
          <p class="mb-1">&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>
          <p class="tax-info" data-tax-info>+18% GST applies</p>
                </div>
            </div>
        </a>
        </div>
    <% } %>
</div>
