<% layout("layouts/boilerplate.ejs") %>

<div class="row">
    <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
        <h2 class="mb-3"><%= listing.title %></h2>

        <div class="card show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-card-img" alt="listing image">
        <div class="card-body show-card-body">
            <% if (listing.owner) { %>
            <p class="show-meta">Hosted by <strong>Travel Nivasa</strong></p>
            <% } %>
            <p class="show-description"><%= listing.description %></p>
            <p class="show-meta"><%= listing.location %>, <%= listing.country %></p>
            <p class="show-price">&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>

             <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
            <div class="show-actions">
            <a href="/listings/<%= listing._id %>/edit" class="btn add-btn">Edit</a>
                <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-dark">Delete</button>
                </form>
                </div>
             <% } %>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-8 offset-lg-2">
        <div class="booking-panel">
            <div class="booking-panel-head">
                <div>
                    <h4 class="mb-1">Book this HomeNook</h4>
                    <p class="booking-subtle mb-0">Choose your stay dates and we will block the slot instantly.</p>
                </div>
                <div class="booking-price-box">
                    <span class="booking-rate">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>
                    <span class="booking-subtle">per night</span>
                </div>
            </div>

            <div class="row g-4 align-items-start">
                <div class="col-lg-6">
                    <% if (!currUser) { %>
                        <div class="booking-note-box">
                            <p class="mb-2">Log in to reserve this HomeNook and lock your stay dates.</p>
                            <a href="/login" class="btn add-btn btn-sm">Log In to Book</a>
                        </div>
                    <% } else if (listing.owner && listing.owner._id.equals(currUser._id)) { %>
                        <div class="booking-note-box">
                            <p class="mb-0">You are the host of this HomeNook, so booking is disabled for your own account.</p>
                        </div>
                    <% } else { %>
                        <form method="post" action="/listings/<%= listing._id %>/bookings" class="needs-validation booking-form" novalidate>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label for="checkIn" class="form-label">Check-in</label>
                                    <input type="date" id="checkIn" name="booking[checkIn]" class="form-control" min="<%= todayDateValue %>" required>
                                    <div class="invalid-feedback">Select a check-in date.</div>
                                </div>
                                <div class="col-md-6">
                                    <label for="checkOut" class="form-label">Check-out</label>
                                    <input type="date" id="checkOut" name="booking[checkOut]" class="form-control" min="<%= todayDateValue %>" required>
                                    <div class="invalid-feedback">Select a check-out date.</div>
                                </div>
                                <div class="col-md-6">
                                    <label for="guests" class="form-label">Guests</label>
                                    <input type="number" id="guests" name="booking[guests]" class="form-control" min="1" max="10" value="1" required>
                                    <div class="invalid-feedback">Choose at least 1 guest.</div>
                                </div>
                            </div>
                            <button class="btn add-btn mt-3">Reserve HomeNook</button>
                        </form>
                    <% } %>
                </div>

                <div class="col-lg-6">
                    <h5 class="mb-2">Unavailable Slots</h5>
                    <% if (bookingSlots.length) { %>
                        <div class="booking-slot-list">
                            <% for (let booking of bookingSlots) { %>
                                <div class="booking-slot-card">
                                    <div class="booking-slot-row">
                                        <strong><%= booking.formattedCheckIn %></strong>
                                        <span>to</span>
                                        <strong><%= booking.formattedCheckOut %></strong>
                                    </div>
                                    <p class="booking-subtle mb-1"><%= booking.totalNights %> night<%= booking.totalNights > 1 ? "s" : "" %> blocked</p>
                                    <% if (booking.guest) { %>
                                        <% if (currUser && booking.guest._id.equals(currUser._id)) { %>
                                            <p class="booking-subtle mb-0">Booked by <strong>You</strong></p>
                                        <% } else { %>
                                            <p class="booking-subtle mb-0">Booked by <strong>Guest</strong></p>
                                        <% } %>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    <% } else { %>
                        <p class="text-muted mb-0">No bookings yet. All upcoming slots are currently open.</p>
                    <% } %>
                </div>
            </div>

            <% if (currUser) { %>
                <% const myBookings = bookingSlots.filter((booking) => booking.guest && booking.guest._id.equals(currUser._id)); %>
                <div class="mt-4">
                    <h5 class="mb-2">Your Bookings</h5>
                    <% if (myBookings.length) { %>
                        <div class="booking-slot-list">
                            <% for (let booking of myBookings) { %>
                                <div class="booking-slot-card">
                                    <div class="booking-slot-row">
                                        <strong><%= booking.formattedCheckIn %></strong>
                                        <span>to</span>
                                        <strong><%= booking.formattedCheckOut %></strong>
                                    </div>
                                    <p class="booking-subtle mb-1"><%= booking.guests %> guest<%= booking.guests > 1 ? "s" : "" %> | <%= booking.totalNights %> night<%= booking.totalNights > 1 ? "s" : "" %></p>
                                    <p class="mb-2">Total: &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></p>
                                    <form method="post" action="/listings/<%= listing._id %>/bookings/<%= booking._id %>?_method=DELETE">
                                        <button class="btn btn-sm btn-dark">Cancel Booking</button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    <% } else { %>
                        <p class="text-muted mb-0">You have not booked this HomeNook yet.</p>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-5 offset-md-0 col-lg-4 offset-lg-2">
        <div class="review-form-box">
        <h4 class="mb-2">Leave a Review</h4>
        <form method="post" action="/listings/<%= listing._id %>/reviews" class="needs-validation" novalidate>
            <div class="mb-2">
            <label class="form-label d-block">Rating</label>
            <div class="star-rating">
            <input type="radio" id="star5" name="review[rating]" value="5" required>
            <label for="star5"><i class="fa-solid fa-star"></i></label>

            <input type="radio" id="star4" name="review[rating]" value="4">
         <label for="star4"><i class="fa-solid fa-star"></i></label>

            <input type="radio" id="star3" name="review[rating]" value="3">
            <label for="star3"><i class="fa-solid fa-star"></i></label>
            <input type="radio" id="star2" name="review[rating]" value="2">
         <label for="star2"><i class="fa-solid fa-star"></i></label>
        <input type="radio" id="star1" name="review[rating]" value="1">
        <label for="star1"><i class="fa-solid fa-star"></i></label>
            </div>
            <div class="valid-feedback">Rating looks good.</div>
            <div class="invalid-feedback">Please select a rating.</div>
            </div>
            <div class="mb-2">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control" placeholder="Share your experience" required></textarea>
            <div class="valid-feedback">Comment looks good.</div>
            <div class="invalid-feedback">Please add a comment.</div>
            </div>
            <button class="btn add-btn review-submit-btn mt-1">Submit</button>
        </form>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
        <h4 class="mb-3">Reviews</h4>

        <% if (listing.reviews.length) { %>
        <div class="row">
        <% for (let review of listing.reviews) { %>
        <div class="col-md-6 mb-3">
        <div class="card review-card">
        <div class="card-body">
        <% if (review.author) { %>
        <p class="show-meta mb-2">Reviewed by <strong><%= review.author.username %></strong></p>
        <% } %>
        <p class="review-rating mb-2">
        <% for (let i = 1; i <= review.rating; i++) { %>
        <i class="fa-solid fa-star"></i>
        <% } %>
        </p>
        <p class="mb-3"><%= review.comment %></p>
        <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
        <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
            <button class="btn btn-sm btn-dark">Delete Review</button>
        </form>
        <% } %>
    </div>
    </div>
    </div>
    <% } %>
    </div>
        <% } else { %>
            <p class="text-muted">No reviews yet.</p>
        <% } %>
    </div>
</div>
