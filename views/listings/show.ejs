<% layout("layouts/boilerplate.ejs") %>

<div class="row">
    <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
        <h2 class="mb-3"><%= listing.title %></h2>

        <div class="card show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-card-img" alt="listing image">
        <div class="card-body show-card-body">
            <% if (listing.owner) { %>
            <p class="show-meta">Hosted by <strong>Travel Nivasa</strong></p>
            <% } %>
            <p class="show-description"><%= listing.description %></p>
            <p class="show-meta"><%= listing.location %>, <%= listing.country %></p>
            <p class="show-price">&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>

             <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
            <div class="show-actions">
            <a href="/listings/<%= listing._id %>/edit" class="btn add-btn">Edit</a>
                <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-dark">Delete</button>
                </form>
                </div>
             <% } %>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-5 offset-md-0 col-lg-4 offset-lg-2">
        <div class="review-form-box">
        <h4 class="mb-2">Leave a Review</h4>
        <form method="post" action="/listings/<%= listing._id %>/reviews" class="needs-validation" novalidate>
            <div class="mb-2">
            <label class="form-label d-block">Rating</label>
            <div class="star-rating">
            <input type="radio" id="star5" name="review[rating]" value="5" required>
            <label for="star5"><i class="fa-solid fa-star"></i></label>

            <input type="radio" id="star4" name="review[rating]" value="4">
         <label for="star4"><i class="fa-solid fa-star"></i></label>

            <input type="radio" id="star3" name="review[rating]" value="3">
            <label for="star3"><i class="fa-solid fa-star"></i></label>
            <input type="radio" id="star2" name="review[rating]" value="2">
         <label for="star2"><i class="fa-solid fa-star"></i></label>
        <input type="radio" id="star1" name="review[rating]" value="1">
        <label for="star1"><i class="fa-solid fa-star"></i></label>
            </div>
            <div class="valid-feedback">Rating looks good.</div>
            <div class="invalid-feedback">Please select a rating.</div>
            </div>
            <div class="mb-2">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control" placeholder="Share your experience" required></textarea>
            <div class="valid-feedback">Comment looks good.</div>
            <div class="invalid-feedback">Please add a comment.</div>
            </div>
            <button class="btn add-btn review-submit-btn mt-1">Submit</button>
        </form>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-10 offset-md-1 col-lg-8 offset-lg-2">
        <h4 class="mb-3">Reviews</h4>

        <% if (listing.reviews.length) { %>
        <div class="row">
        <% for (let review of listing.reviews) { %>
        <div class="col-md-6 mb-3">
        <div class="card review-card">
        <div class="card-body">
        <% if (review.author) { %>
        <p class="show-meta mb-2">Reviewed by <strong><%= review.author.username %></strong></p>
        <% } %>
        <p class="review-rating mb-2">
        <% for (let i = 1; i <= review.rating; i++) { %>
        <i class="fa-solid fa-star"></i>
        <% } %>
        </p>
        <p class="mb-3"><%= review.comment %></p>
        <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
        <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
            <button class="btn btn-sm btn-dark">Delete Review</button>
        </form>
        <% } %>
    </div>
    </div>
    </div>
    <% } %>
    </div>
        <% } else { %>
            <p class="text-muted">No reviews yet.</p>
        <% } %>
    </div>
</div>
