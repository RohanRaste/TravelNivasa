<% layout("layouts/boilerplate.ejs") %>
<div class="row">
<div class="col-md-8 offset-md-2 col-lg-6 offset-lg-3">
<h2 class="mb-3">Sign Up</h2>
<form method="post" action="/signup" class="needs-validation" novalidate>
    <div class="mb-2">
        <label for="username" class="form-label">Username</label>
        <input
        id="username"
        name="username"
        placeholder="Choose a username"
        type="text"
        class="form-control"
        required
        />
        <div class="valid-feedback">Username looks good.</div>
        <div class="invalid-feedback">Please enter a username.</div>
    </div>

    <div class="mb-2">
        <label for="email" class="form-label">Email</label>
        <input
        id="email"
        name="email"
        placeholder="Enter your email"
        type="email"
        class="form-control"
        required
        />
        <div class="valid-feedback">Email looks good.</div>
        <div class="invalid-feedback">Please enter a valid email.</div>
    </div>

    <div class="mb-2">
        <label for="password" class="form-label">Password</label>
        <input
        id="password"
        name="password"
        placeholder="Create a password"
        type="password"
        class="form-control"
        required
        />
        <div class="valid-feedback">Password looks good.</div>
        <div class="invalid-feedback">Please enter a password.</div>
    </div>

    <button class="btn add-btn mt-2">Sign Up</button>
</form>
</div>
</div>
